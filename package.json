{
  "name": "smartstadium-ai",
  "version": "2.0.0",
  "description": "SmartStadium AI — Real-time crowd management platform powered by Google Cloud",
  "main": "server/index.js",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest --coverage --forceExit",
    "test:unit": "jest tests/unit --coverage --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "test:e2e": "npx playwright test",
    "lint": "eslint . --ext .js --ignore-path .gitignore",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.3.0",
    "@google-cloud/logging": "^11.0.0",
    "@google-cloud/pubsub": "^4.3.0",
    "@google-cloud/secret-manager": "^5.5.0",
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/translate": "^8.3.0",
    "@google/generative-ai": "^0.21.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.1",
    "axe-core": "^4.8.4",
    "jest": "^29.7.0",
    "jest-mock": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
