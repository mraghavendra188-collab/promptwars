# ─── SmartStadium AI — Environment Variables ─────────────────────────────────
# Copy to .env and fill in real values.
# NEVER commit your actual .env file to version control.
# In production, all secrets are stored in Google Secret Manager.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=sublime-oxygen-493515-n7
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key          # Server-side only (from AI Studio or Vertex)
GEMINI_WEB_API_KEY=your-gemini-web-key      # Client-side (restricted by HTTP referrer)
GEMINI_MODEL=gemini-1.5-flash               # or gemini-1.5-pro

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSyDPy5jb-sJFocm10pv2Zfj_D2Q0M4PgMvQ       # Restricted to your domain in production

# ── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-firebase-app-id

# ── Cloud Storage ─────────────────────────────────────────────────────────────
STORAGE_BUCKET=your-project-id.appspot.com

# ── BigQuery ──────────────────────────────────────────────────────────────────
BIGQUERY_DATASET=smartstadium
BIGQUERY_TABLE=crowd_events

# ── Cloud Pub/Sub ─────────────────────────────────────────────────────────────
PUBSUB_TOPIC_CROWD=crowd-events
PUBSUB_TOPIC_GATES=gate-scans
PUBSUB_TOPIC_ALERTS=crowd-alerts

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                        # production | development | test
ALLOWED_ORIGINS=http://localhost:3000       # Comma-separated in production

# ── Secret Manager (production only) ─────────────────────────────────────────
# In production these are pulled from Secret Manager:
# SECRET_MANAGER_PROJECT=your-project-id
